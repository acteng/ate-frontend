{
  "name": "@active-travel-england/ate-frontend",
  "version": "0.1.0-alpha.8",
  "description": "Active Travel England templates and styles for digital services.",
  "homepage": "https://github.com/acteng/ate-frontend#readme",
  "bugs": {
    "url": "https://github.com/acteng/ate-frontend/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mark Hobson",
    "email": "mark.hobson@activetravelengland.gov.uk"
  },
  "files": [
    "dist/",
    "govuk-prototype-kit.config.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acteng/ate-frontend.git"
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "ate-frontend:copy-files": "mkdir -p dist/ && cp -rT src/ate/ dist/ate/",
    "ate-frontend:build-css": "sass --style compressed src/ate/index.scss dist/ate/ate-frontend.min.css",
    "ate-frontend:build": "npm run ate-frontend:copy-files && npm run ate-frontend:build-css",
    "govuk-frontend:build-css": "sass --style compressed --load-path=node_modules/govuk-frontend/dist src/ate/govuk-frontend.scss dist/ate/govuk-frontend-ate.min.css",
    "govuk-frontend:build": "npm run govuk-frontend:build-css",
    "govuk-one-login-service-header:build-css": "sass --style compressed --load-path=node_modules/govuk-frontend/dist --load-path=node_modules/@govuk-one-login/service-header/dist/styles src/ate/govuk-one-login-service-header.scss dist/ate/govuk-one-login-service-header-ate.min.css",
    "govuk-one-login-service-header:build": "npm run govuk-one-login-service-header:build-css",
    "build": "npm run clean && npm run ate-frontend:build && npm run govuk-frontend:build && npm run govuk-one-login-service-header:build"
  },
  "dependencies": {
    "@govuk-one-login/service-header": "~6.0.0",
    "govuk-frontend": "~6.1.0"
  },
  "devDependencies": {
    "sass": "~1.99.0"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
