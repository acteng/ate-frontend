From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mark Hobson <mark.hobson@activetravelengland.gov.uk>
Date: Mon, 20 Apr 2026 11:41:17 +0100
Subject: [PATCH] Replace GOV.UK icons with ATE icons

---
 src/ate/assets/ate-icons/manifest.json | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/src/ate/assets/ate-icons/manifest.json b/src/ate/assets/ate-icons/manifest.json
index 0d183a2..fb27dce 100644
--- a/src/ate/assets/ate-icons/manifest.json
+++ b/src/ate/assets/ate-icons/manifest.json
@@ -1,36 +1,36 @@
 {
   "icons": [
     {
-      "src": "images/favicon.ico",
+      "src": "favicon.ico",
       "type": "image/x-icon",
       "sizes": "48x48"
     },
     {
-      "src": "images/favicon.svg",
+      "src": "favicon.svg",
       "type": "image/svg+xml",
       "sizes": "150x150",
       "purpose": "any"
     },
     {
-      "src": "images/govuk-icon-180.png",
+      "src": "ate-icon-180.png",
       "type": "image/png",
       "sizes": "180x180",
       "purpose": "maskable"
     },
     {
-      "src": "images/govuk-icon-192.png",
+      "src": "ate-icon-192.png",
       "type": "image/png",
       "sizes": "192x192",
       "purpose": "maskable"
     },
     {
-      "src": "images/govuk-icon-512.png",
+      "src": "ate-icon-512.png",
       "type": "image/png",
       "sizes": "512x512",
       "purpose": "maskable"
     },
     {
-      "src": "images/govuk-icon-mask.svg",
+      "src": "ate-icon-mask.svg",
       "type": "image/svg+xml",
       "sizes": "150x150",
       "purpose": "monochrome"
