{# govuk-organisation-colour("department-for-transport") #}
{%- set themeColor = themeColor | default("#006853", true) -%}

{% extends "govuk/template.njk" %}
{% from "ate/components/ate-header/macro.njk" import ateHeader %}
{% from "ate/components/ate-footer/macro.njk" import ateFooter %}

{% block headIcons %}
    <link rel="icon" sizes="48x48" href="{{ assetPath }}/ate-icons/favicon.ico">
    <link rel="icon" sizes="any" href="{{ assetPath }}/ate-icons/favicon.svg" type="image/svg+xml">
    <link rel="mask-icon" href="{{ assetPath }}/ate-icons/ate-icon-mask.svg" color="{{ themeColor }}">
    <link rel="apple-touch-icon" href="{{ assetPath }}/ate-icons/ate-icon-180.png">
    <link rel="manifest" href="{{ assetPath }}/ate-icons/manifest.json">
{% endblock %}

{% block govukHeader %}
    {{ ateHeader({
        assetPath: assetPath
    }) }}
{% endblock %}

{% block govukFooter %}
    {{ ateFooter({}) }}
{% endblock %}
