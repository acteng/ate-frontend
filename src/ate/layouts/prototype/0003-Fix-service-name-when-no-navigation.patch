--- a/src/ate/layouts/prototype/service-template.njk
+++ b/src/ate/layouts/prototype/service-template.njk
@@ -52,7 +52,9 @@
     {%- else -%}
       {{ ateServiceHeader({
         assetPath: assetPath,
-        serviceName: serviceName, 
