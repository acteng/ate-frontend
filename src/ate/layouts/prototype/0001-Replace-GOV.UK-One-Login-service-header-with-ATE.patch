From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mark Hobson <mark.hobson@activetravelengland.gov.uk>
Date: Tue, 14 Apr 2026 11:55:50 +0100
Subject: [PATCH] Replace GOV.UK One Login service header with ATE

---
 src/ate/layouts/prototype/service-template.njk | 12 ++++++++----
 1 file changed, 8 insertions(+), 4 deletions(-)

diff --git a/src/ate/layouts/prototype/service-template.njk b/src/ate/layouts/prototype/service-template.njk
index b617a7e..494693e 100644
--- a/src/ate/layouts/prototype/service-template.njk
+++ b/src/ate/layouts/prototype/service-template.njk
@@ -1,5 +1,6 @@
+{%- set assetPath = assetPath | default("/plugin-assets/ate-frontend/src/ate/assets") -%}
+
 {% extends "govuk-prototype-kit/layouts/govuk-branded.njk" %}
-{% from "../service-header.njk" import govukOneLoginServiceHeader %}
 
 {% block header %}
     {%- if navigationItems -%}
@@ -11,7 +12,8 @@
             active: item.id == activeLinkId
         }) -}}
       {%- endfor -%}
-      {{ govukOneLoginServiceHeader({
+      {{ ateServiceHeader({
+        assetPath: assetPath,
         serviceNavigationParams: {
           serviceName: serviceName,
           lng: lng,
@@ -30,7 +32,8 @@
         oneLoginLink: oneLoginLink
       }) if serviceName }}
     {%- elif navigation -%}
-      {{ govukOneLoginServiceHeader({
+      {{ ateServiceHeader({
+        assetPath: assetPath,
         signOutLink: signOutLink,
         lng: lng,
         oneLoginLink: oneLoginLink,
@@ -49,7 +52,8 @@
         }
       }) if serviceName }}
     {%- else -%}
-      {{ govukOneLoginServiceHeader({ 
+      {{ ateServiceHeader({
+        assetPath: assetPath,
         serviceName: serviceName, 
         lng: lng,
         serviceUrl: serviceUrl,
-- 
