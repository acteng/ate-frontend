{
  "meta": {
    "description": "ATE templates and styles for the web."
  },
  "pluginDependencies": [
    {
      "packageName": "govuk-frontend",
      "minVersion": "6.1.0"
    },
    {
      "packageName": "@govuk-one-login/service-header",
      "minVersion": "5.0.0"
    }
  ],
  "assets": [
    "/src/ate/assets/"
  ],
  "nunjucksPaths": [
    "/src/"
  ],
  "nunjucksMacros": [
    {
      "macroName": "ateHeader",
      "importFrom": "ate/components/ate-header/macro.njk"
    },
    {
      "macroName": "ateFooter",
      "importFrom": "ate/components/ate-footer/macro.njk"
    },
    {
      "macroName": "ateServiceHeader",
      "importFrom": "ate/components/ate-service-header/macro.njk"
    }
  ],
  "sass": [
    "/src/ate/index.scss"
  ],
  "templates": [
    {
      "name": "Blank ATE page",
      "path": "/src/ate/templates/blank-ate.njk",
      "type": "nunjucks"
    },
    {
      "name": "Blank ATE service page",
      "path": "/src/ate/templates/blank-ate-service.njk",
      "type": "nunjucks"
    }
  ]
}
